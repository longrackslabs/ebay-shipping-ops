# eBay Fulfillment API credentials (separate from ebay-mcp)
EBAY_CLIENT_ID=your_client_id
EBAY_CLIENT_SECRET=your_client_secret
EBAY_REFRESH_TOKEN=your_refresh_token

# EasyPost API key (test key starts with EZTK)
EASYPOST_API_KEY=your_easypost_api_key

# Shipping from address
FROM_NAME="George Peden"
FROM_STREET="123 Main St"
FROM_CITY="Your City"
FROM_STATE="CO"
FROM_ZIP="80000"

# Printer name (CUPS printer name for Rollo)
PRINTER_NAME=Rollo

# Polling interval in seconds (default: 300 = 5 minutes)
POLL_INTERVAL=300
